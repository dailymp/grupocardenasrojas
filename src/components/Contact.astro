---
---

<section
  id="contacto"
  class="py-24 bg-accent-900 overflow-hidden"
  aria-labelledby="contact-title"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: contact info -->
      <div class="space-y-8">
        <div>
          <div class="mb-4 reveal">
            <span class="badge-dark">Contacto directo</span>
          </div>
          <h2 id="contact-title" class="section-title-light mb-2 reveal">
            Hablemos de<br/> <span class="text-brand-400">tu proyecto</span>
          </h2>
          <div class="section-divider mt-4 reveal"></div>
        </div>

        <p class="section-subtitle-light reveal">
          Estamos disponibles para asesorarte. Consúltanos por WhatsApp, email o síguenos en redes sociales.
        </p>

        <!-- Contact cards -->
        <div class="space-y-4 reveal">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/34644792795?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20sus%20servicios."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 bg-accent-800 border border-accent-700 rounded-2xl hover:border-green-500/50 hover:bg-accent-700 transition-all duration-200 group"
            aria-label="Contactar por WhatsApp: 644 79 27 95"
          >
            <div class="w-12 h-12 bg-green-500/15 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-green-500 transition-colors duration-200">
              <svg class="w-6 h-6 text-green-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-accent-400 uppercase tracking-widest font-medium mb-0.5">WhatsApp</p>
              <p class="text-white font-bold text-lg">644 79 27 95</p>
            </div>
            <svg class="w-5 h-5 text-accent-600 group-hover:text-brand-400 ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>

          <!-- Email -->
          <a
            href="mailto:contacto@grupocardenasrojas.com"
            class="flex items-center gap-4 p-5 bg-accent-800 border border-accent-700 rounded-2xl hover:border-brand-500/50 hover:bg-accent-700 transition-all duration-200 group"
            aria-label="Enviar email a contacto@grupocardenasrojas.com"
          >
            <div class="w-12 h-12 bg-brand-600/15 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-brand-600 transition-colors duration-200">
              <svg class="w-6 h-6 text-brand-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-accent-400 uppercase tracking-widest font-medium mb-0.5">Email</p>
              <p class="text-white font-bold">contacto@grupocardenasrojas.com</p>
            </div>
            <svg class="w-5 h-5 text-accent-600 group-hover:text-brand-400 ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href="https://instagram.com/grupocardenasrojas"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 bg-accent-800 border border-accent-700 rounded-2xl hover:border-pink-500/50 hover:bg-accent-700 transition-all duration-200 group"
            aria-label="Seguir en Instagram @grupocardenasrojas"
          >
            <div class="w-12 h-12 bg-pink-600/15 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-gradient-to-br group-hover:from-purple-500 group-hover:to-pink-500 transition-all duration-200">
              <svg class="w-6 h-6 text-pink-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-accent-400 uppercase tracking-widest font-medium mb-0.5">Instagram</p>
              <p class="text-white font-bold">@grupocardenasrojas</p>
            </div>
            <svg class="w-5 h-5 text-accent-600 group-hover:text-brand-400 ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>

        </div>
      </div>

      <!-- Right: visual / stats card -->
      <div class="reveal-right">
        <div class="bg-accent-800 border border-accent-700 rounded-3xl p-8 space-y-8">

          <!-- Headline -->
          <div class="text-center">
            <div class="w-20 h-20 bg-brand-gradient rounded-2xl mx-auto flex items-center justify-center mb-4 shadow-glow">
              <img src="/logo.png" alt="Logo Grupo Cárdenas Rojas" class="w-12 h-12 object-contain" />
            </div>
            <h3 class="font-display text-2xl font-black text-white uppercase tracking-wide">Grupo Cárdenas Rojas</h3>
            <p class="text-accent-400 text-sm mt-1">Reformas integrales con acabados de alta calidad</p>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 py-6 border-y border-accent-700">
            <div class="text-center">
              <p class="font-display text-3xl font-black text-brand-400 leading-none">20</p>
              <p class="text-accent-400 text-xs uppercase tracking-widest mt-1">Años exp.</p>
            </div>
            <div class="text-center border-x border-accent-700">
              <p class="font-display text-3xl font-black text-brand-400 leading-none">+300</p>
              <p class="text-accent-400 text-xs uppercase tracking-widest mt-1">Obras</p>
            </div>
            <div class="text-center">
              <p class="font-display text-3xl font-black text-brand-400 leading-none">100%</p>
              <p class="text-accent-400 text-xs uppercase tracking-widest mt-1">Garantía</p>
            </div>
          </div>

          <!-- Availability -->
          <div class="flex items-center gap-3 bg-accent-900 rounded-xl p-4">
            <div class="w-2.5 h-2.5 bg-green-400 rounded-full flex-shrink-0 animate-pulse" aria-hidden="true"></div>
            <div>
              <p class="text-white text-sm font-semibold">Disponibles ahora</p>
              <p class="text-accent-400 text-xs">Lun–Vie · 8:00–19:00</p>
            </div>
          </div>

          <a
            href="https://wa.me/34632830169?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto%20sin%20compromiso."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full justify-center"
            aria-label="Pedir presupuesto ahora"
          >
            Pedir presupuesto ahora
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
