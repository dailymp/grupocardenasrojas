---
---

<section
  id="nosotros"
  class="py-24 bg-white overflow-hidden"
  aria-labelledby="about-title"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: image collage -->
      <div class="relative reveal-left">
        <!-- Main image -->
        <div class="relative z-10 overflow-hidden rounded-3xl shadow-card-hover aspect-square">
          <img
            src="/gallery/proyecto-2.png"
            alt="Trabajo de reforma y construcción de alta calidad por Grupo Cárdenas Rojas"
            class="w-full h-full object-contain bg-white"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-accent-950/40 to-transparent"></div>
        </div>

        <!-- Decorative offset shape -->
        <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-brand-gradient rounded-3xl -z-10 opacity-80" aria-hidden="true"></div>
        <div class="absolute -top-6 -left-6 w-32 h-32 border-2 border-brand-200 rounded-3xl -z-10" aria-hidden="true"></div>

        <!-- Experience badge overlaid -->
        <div class="absolute -bottom-6 -left-6 z-20 bg-white rounded-2xl shadow-card px-6 py-4 flex items-center gap-4">
          <div class="w-14 h-14 bg-brand-gradient rounded-2xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <div>
            <p class="font-display text-3xl font-black text-warm-900 leading-none">20</p>
            <p class="text-sm text-warm-500 font-medium uppercase tracking-widest">años de experiencia</p>
          </div>
        </div>
      </div>

      <!-- Right: text column -->
      <div class="space-y-7">
        <div class="reveal">
          <span class="badge">Sobre nosotros</span>
        </div>

        <div class="reveal">
          <h2 id="about-title" class="section-title">
            Construimos con <span class="text-brand-600">excelencia</span> y compromiso
          </h2>
        </div>

        <div class="section-divider reveal"></div>

        <p class="text-warm-600 leading-relaxed text-lg reveal">
          Somos <strong class="text-warm-900 font-semibold">Grupo Cárdenas Rojas</strong>, una empresa especializada en reformas integrales y construcción de viviendas. Con más de dos décadas de trayectoria, ofrecemos asesoramiento técnico desde la fase inicial del proyecto y gestionamos integralmente todo el proceso, dejando la toma de decisiones en manos del cliente.
        </p>

        <p class="text-warm-500 leading-relaxed reveal">
          Cada obra es única. Trabajamos con los mejores materiales y profesionales del sector para garantizar que tu hogar o negocio quede exactamente como lo imaginas, dentro del plazo acordado y sin sorpresas en el presupuesto.
        </p>

        <!-- Feature pillars -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2 reveal">

          {[
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Presupuesto sin compromiso', desc: 'Te asesoramos sin coste previo' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Cumplimiento de plazos', desc: 'Entregamos en el tiempo acordado' },
            { icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', title: 'Materiales de calidad', desc: 'Solo proveedores homologados' },
            { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Garantía en todos los trabajos', desc: 'Respaldamos cada proyecto' },
          ].map(f => (
            <div class="flex items-start gap-3 p-4 rounded-xl bg-warm-50 hover:bg-brand-50 transition-colors duration-200 group">
              <div class="icon-box mt-0.5 flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon}/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-warm-900 text-sm">{f.title}</p>
                <p class="text-warm-500 text-xs mt-0.5">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="reveal pt-2">
          <a
            href="https://wa.me/34632830169?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto%20sin%20compromiso."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline-dark inline-flex"
            aria-label="Contactar con Grupo Cárdenas Rojas"
          >
            Hablar con un experto
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
