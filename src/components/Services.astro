---
const services = [
  {
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    title: 'Reformas integrales',
    subtitle: 'Llave en mano',
    desc: 'Nos encargamos de todo: proyecto, permisos, ejecución y entrega. Tu obra, sin estrés.',
  },
  {
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    title: 'Construcción de viviendas',
    subtitle: 'Personalizadas',
    desc: 'Edificamos tu hogar desde cero, adaptado a tus necesidades y estilo de vida.',
  },
  {
    icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
    title: 'Cocinas y baños',
    subtitle: 'A medida',
    desc: 'Diseñamos y ejecutamos espacios funcionales y estéticamente impecables, adaptados a cada metro.',
  },
  {
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    title: 'Carpintería y acabados',
    subtitle: 'Interiores',
    desc: 'Revestimientos, suelos, techos, armarios a medida y todo tipo de acabados de alta calidad.',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Instalaciones completas',
    subtitle: 'Fontanería y electricidad',
    desc: 'Equipo certificado para toda la parte técnica: fontanería, electricidad, climatización y más.',
  },
  {
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    title: 'Rehabilitación de fachadas',
    subtitle: 'Mejora y restauración',
    desc: 'Renovamos la imagen exterior de tu edificio con técnicas modernas y materiales duraderos.',
  },
];
---

<section
  id="servicios"
  class="py-24 bg-dark-section overflow-hidden"
  aria-labelledby="services-title"
>
  <!-- Top diagonal clip -->
  <div class="w-full overflow-hidden -mt-1 mb-16" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-12 fill-white -mt-px">
      <polygon points="0,0 1440,0 1440,60 0,0"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="flex justify-center mb-4 reveal">
        <span class="badge-dark">Nuestros servicios</span>
      </div>
      <h2 id="services-title" class="section-title-light mb-4 reveal">
        Soluciones <span class="text-brand-400">completas</span> para tu obra
      </h2>
      <div class="flex justify-center mb-6 reveal">
        <div class="section-divider"></div>
      </div>
      <p class="section-subtitle-light mx-auto reveal">
        Desde el primer diseño hasta la entrega de llaves, cubrimos cada etapa del proceso constructivo con los más altos estándares.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div
          class="service-card reveal"
          style={`transition-delay:${i * 80}ms`}
        >
          <!-- Icon + title row -->
          <div class="flex items-start gap-4 mb-4">
            <div class="icon-box-dark group-hover:bg-brand-600 group-hover:text-white flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-brand-400 font-semibold uppercase tracking-widest mb-0.5">{s.subtitle}</p>
              <h3 class="font-display text-xl font-bold text-white uppercase tracking-wide leading-tight">{s.title}</h3>
            </div>
          </div>

          <!-- Description -->
          <p class="text-accent-400 text-sm leading-relaxed">{s.desc}</p>

          <!-- Hover arrow -->
          <div class="mt-4 flex items-center gap-2 text-brand-500 text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-200">
            Solicitar presupuesto
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA row -->
    <div class="mt-14 text-center reveal">
      <p class="text-accent-400 mb-6 text-base">¿No encuentras lo que necesitas? Consúltanos sin compromiso.</p>
      <a
        href="https://wa.me/34632830169?text=Hola%2C%20tengo%20una%20consulta%20sobre%20un%20servicio%20de%20reforma."
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        aria-label="Consultar servicio por WhatsApp"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Pedir presupuesto personalizado
      </a>
    </div>

  </div>

  <!-- Bottom diagonal clip -->
  <div class="w-full overflow-hidden mt-16 -mb-1" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" class="w-full h-12 fill-white">
      <polygon points="0,60 1440,0 1440,60 0,60"/>
    </svg>
  </div>
</section>
