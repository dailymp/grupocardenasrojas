---
const testimonials = [
  {
    name: 'María González',
    role: 'Propietaria de vivienda',
    stars: 5,
    text: 'Grupo Cárdenas Rojas transformó completamente nuestra cocina y baño. Puntualidad, limpieza y un acabado impecable. 100% recomendables.',
    initial: 'M',
  },
  {
    name: 'Carlos Fernández',
    role: 'Promotor inmobiliario',
    stars: 5,
    text: 'Llevamos 3 proyectos con ellos y siempre cumplen con los plazos y presupuestos. Un equipo profesional y serio que sabe lo que hace.',
    initial: 'C',
  },
  {
    name: 'Ana y Roberto Martín',
    role: 'Reforma integral de vivienda',
    stars: 5,
    text: 'Desde el primer momento nos asesoraron perfectamente. La gestión integral es un diferencial enorme; no tuvimos que preocuparnos de nada. El resultado superó expectativas.',
    initial: 'A',
  },
];
---

<section
  id="testimonios"
  class="py-24 bg-white overflow-hidden"
  aria-labelledby="testimonials-title"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="flex justify-center mb-4 reveal">
        <span class="badge">Testimonios</span>
      </div>
      <h2 id="testimonials-title" class="section-title mb-4 reveal">
        Lo que dicen <span class="text-brand-600">nuestros clientes</span>
      </h2>
      <div class="flex justify-center mb-6 reveal">
        <div class="section-divider"></div>
      </div>
      <p class="section-subtitle mx-auto reveal">
        Más de 300 familias y empresas han confiado en nosotros para transformar sus espacios.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div
          class="reveal bg-warm-50 rounded-3xl p-8 border border-warm-200 hover:border-brand-200 hover:bg-brand-50/50 transition-all duration-300"
          style={`transition-delay:${i * 120}ms`}
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-5" aria-label={`${t.stars} de 5 estrellas`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote icon -->
          <svg class="w-8 h-8 text-brand-200 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>

          <!-- Text -->
          <p class="text-warm-600 leading-relaxed mb-6 italic">"{t.text}"</p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-brand-gradient rounded-full flex items-center justify-center flex-shrink-0">
              <span class="font-display font-black text-white text-sm">{t.initial}</span>
            </div>
            <div>
              <p class="font-semibold text-warm-900 text-sm">{t.name}</p>
              <p class="text-warm-500 text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Overall rating -->
    <div class="mt-14 text-center reveal">
      <div class="inline-flex items-center gap-3 bg-warm-50 border border-warm-200 rounded-full px-7 py-3">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="font-bold text-warm-900">5.0</span>
        <span class="text-warm-500 text-sm">· Valoración media de nuestros clientes</span>
      </div>
    </div>

  </div>
</section>
