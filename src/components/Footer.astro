---
const year = new Date().getFullYear();

const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#testimonios', label: 'Testimonios' },
  { href: '#contacto', label: 'Contacto' },
];

const services = [
  'Reformas integrales llave en mano',
  'Construcción de viviendas',
  'Cocinas y baños a medida',
  'Carpintería y acabados',
  'Instalaciones completas',
  'Rehabilitación de fachadas',
];
---

<footer class="bg-warm-950 text-warm-400" aria-label="Pie de página">

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand column (col-span-2 on large) -->
      <div class="lg:col-span-2 space-y-5">
        <!-- Logo + name -->
        <a href="/" class="flex items-center gap-3 group" aria-label="Grupo Cárdenas Rojas — Inicio">
          <img src="/logo.png" alt="Logo Grupo Cárdenas Rojas" class="w-12 h-12 flex-shrink-0 object-contain" />
          <div>
            <p class="text-xs text-accent-500 font-semibold uppercase tracking-[0.2em]">Grupo</p>
            <p class="font-display text-xl font-black text-white uppercase tracking-[0.12em]">Cárdenas Rojas</p>
          </div>
        </a>

        <p class="text-warm-400 leading-relaxed text-sm max-w-sm">
          Reformas integrales con acabados de alta calidad. 20 años de experiencia construyendo espacios que transforman vidas, con el máximo compromiso y garantía en cada proyecto.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-3">
          <!-- Instagram -->
          <a
            href="https://instagram.com/grupocardenasrojas"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-warm-800 rounded-xl flex items-center justify-center hover:bg-gradient-to-br hover:from-purple-500 hover:to-pink-500 transition-all duration-200 group"
            aria-label="Instagram de Grupo Cárdenas Rojas"
          >
            <svg class="w-5 h-5 text-warm-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>

          <!-- TikTok -->
          <a
            href="https://tiktok.com/@grupocardenasrojas"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-warm-800 rounded-xl flex items-center justify-center hover:bg-warm-700 transition-all duration-200 group"
            aria-label="TikTok de Grupo Cárdenas Rojas"
          >
            <svg class="w-5 h-5 text-warm-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.23 8.23 0 004.84 1.56V6.78a4.85 4.85 0 01-1.07-.09z"/>
            </svg>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/34632830169"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-warm-800 rounded-xl flex items-center justify-center hover:bg-green-600 transition-all duration-200 group"
            aria-label="WhatsApp de Grupo Cárdenas Rojas"
          >
            <svg class="w-5 h-5 text-warm-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-widest text-sm mb-5">Navegación</h3>
        <ul class="space-y-2.5">
          {navLinks.map(l => (
            <li>
              <a href={l.href} class="text-warm-400 hover:text-brand-400 transition-colors text-sm flex items-center gap-2">
                <span class="w-1 h-1 bg-brand-600 rounded-full flex-shrink-0" aria-hidden="true"></span>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-widest text-sm mb-5">Servicios</h3>
        <ul class="space-y-2.5">
          {services.map(s => (
            <li class="text-warm-400 text-sm flex items-start gap-2">
              <span class="w-1 h-1 bg-brand-600 rounded-full flex-shrink-0 mt-2" aria-hidden="true"></span>
              {s}
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <div class="border-t border-warm-800 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-warm-500 text-sm text-center md:text-left">
          © {year} <span class="text-warm-300 font-medium">Grupo Cárdenas Rojas</span>. Todos los derechos reservados.
        </p>
        <p class="text-warm-500 text-sm text-center md:text-right">
          Reformas integrales · España ·
          Desarrollado por
          <a
            href="https://dailymp.es"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-400 hover:text-brand-300 transition-colors font-medium"
            aria-label="Ir al sitio de DailyMP"
          >
            DailyMP
          </a>
        </p>
      </div>
    </div>

  </div>
</footer>
