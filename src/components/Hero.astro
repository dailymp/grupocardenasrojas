---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center overflow-hidden bg-hero-gradient"
  aria-label="Hero — Grupo Cárdenas Rojas"
>
  <!-- Background image overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="/hero-bg.webp"
      alt="Proyecto de reforma integral de alta calidad ejecutado por Grupo Cárdenas Rojas"
      class="w-full h-full object-cover opacity-15"
      loading="eager"
    />
    <!-- Gradient over the image -->
    <div class="absolute inset-0 bg-gradient-to-r from-accent-950/95 via-accent-950/80 to-brand-950/70"></div>
  </div>

  <!-- Decorative blue diagonal shapes -->
  <div class="absolute top-0 right-0 w-1/2 h-full z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <!-- Large diagonal block top-right -->
    <div class="absolute -top-20 -right-40 w-[700px] h-[700px] bg-brand-gradient opacity-20 rotate-12 rounded-3xl"></div>
    <!-- Smaller accent block -->
    <div class="absolute top-40 right-0 w-[400px] h-[400px] bg-brand-600 opacity-10 -rotate-6 rounded-2xl"></div>
    <!-- Glowing orb -->
    <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-brand-500 opacity-15 blur-3xl rounded-full animate-pulse-slow"></div>
  </div>

  <!-- Bottom geometric line element -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-600/50 to-transparent z-10" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-24 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: text column -->
      <div class="space-y-7">
        <!-- Location / category badge -->
        <div class="badge-dark animate-fade-in" style="animation-delay:0.1s">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          Construcción &amp; Reformas — España
        </div>

        <!-- H1 -->
        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-black text-white uppercase leading-[1.0] tracking-tight animate-fade-up" style="animation-delay:0.2s">
          Reformas <br/>
          <span class="text-brand-400">integrales</span><br/>
          de alta calidad
        </h1>

        <!-- Decorative underline -->
        <div class="w-20 h-1.5 bg-brand-500 rounded-full animate-slide-right" style="animation-delay:0.35s" aria-hidden="true"></div>

        <!-- Subtitle -->
        <p class="text-lg text-accent-300 leading-relaxed max-w-xl animate-fade-up" style="animation-delay:0.4s">
          Tu proyecto, nuestro compromiso. Gestionamos integralmente cada obra desde el diseño hasta la entrega de llaves, con <strong class="text-white font-semibold">20 años de experiencia garantizada</strong>.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 animate-fade-up" style="animation-delay:0.5s">
          <a
            href="https://wa.me/34632830169?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20y%20un%20presupuesto%20sin%20compromiso%20para%20una%20obra%20o%20reforma.%20Quedo%20a%20la%20espera%20de%20vuestro%20contacto.%20Gracias."
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            aria-label="Pedir presupuesto gratis por WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Pedir presupuesto gratis
          </a>
          <a href="#proyectos" class="btn-outline" aria-label="Ver proyectos realizados">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Ver proyectos
          </a>
        </div>

        <!-- Stats bar -->
        <div class="flex items-center gap-0 pt-4 animate-fade-up" style="animation-delay:0.6s">
          <div class="stat-item pr-6">
            <span class="stat-number">20</span>
            <span class="stat-label">Años de exp.</span>
          </div>
          <div class="w-px h-12 bg-accent-700 mx-2" aria-hidden="true"></div>
          <div class="stat-item px-6">
            <span class="stat-number">+300</span>
            <span class="stat-label">Obras realizadas</span>
          </div>
          <div class="w-px h-12 bg-accent-700 mx-2" aria-hidden="true"></div>
          <div class="stat-item pl-6">
            <span class="stat-number">100%</span>
            <span class="stat-label">Garantía</span>
          </div>
        </div>
      </div>

      <!-- Right: visual column -->
      <div class="relative flex items-center justify-center animate-fade-in" style="animation-delay:0.4s" aria-hidden="true">

        <!-- Main image in diagonal frame -->
        <div class="relative w-full max-w-xl mx-auto px-8 py-10">
          <!-- Outer decorative frame -->
          <div class="absolute inset-2 bg-brand-600/20 rounded-3xl rotate-3 blur-sm"></div>
          <div class="absolute inset-3 border border-brand-500/30 rounded-3xl rotate-2"></div>

          <!-- Image container -->
          <div class="relative overflow-hidden rounded-3xl shadow-glow-lg aspect-square">
            <img
              src="/gallery/proyecto-1.webp"
              alt="Reforma integral de alta calidad — Grupo Cárdenas Rojas"
              class="w-full h-full object-cover"
              width="960"
              height="960"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
            <!-- Blue diagonal overlay -->
            <div class="absolute inset-0 bg-gradient-to-br from-brand-600/30 to-transparent"></div>
          </div>

          <!-- Floating badge — top -->
          <div class="absolute top-0 -right-2 bg-brand-gradient text-white text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full shadow-glow flex items-center gap-1.5">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Calidad garantizada
          </div>

          <!-- Floating badge — bottom -->
          <div class="absolute bottom-0 -left-2 bg-accent-900 border border-accent-700 text-warm-200 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full shadow-card flex items-center gap-1.5">
            <svg class="w-3 h-3 text-brand-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Llave en mano
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce" aria-hidden="true">
    <a href="#nosotros" class="flex flex-col items-center gap-2 text-accent-500 hover:text-brand-400 transition-colors" aria-label="Ir a sección nosotros">
      <span class="text-xs uppercase tracking-widest font-medium">Descubrir</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>
